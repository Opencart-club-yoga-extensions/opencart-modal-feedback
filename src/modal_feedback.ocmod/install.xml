<?xml version="1.0" encoding="utf-8"?>
<modification>
    <name>Cookie message</name>
    <code>cookiemessage</code>
    <version>1.0.0.1</version>
    <author>qMalmind | expoa.ru</author>
    <link>info@expoa.ru</link>

    <!-- Catalog / Header -->
	<file path="catalog/controller/common/header.php">
		<operation>
			<search>
				<![CDATA[
					return $this->load->view('common/header', $data);
				]]>
			</search>
			<add position="before">
				<![CDATA[
					// 	<yoga_feedback_extension>

					$this->load->model('setting/setting');
					if($this->model_setting_setting->getSettingValue('module_yoga_feedback_status')){
						$data['feedback_form'] = $this->load->controller('extension/module/yoga_feedback');
					}else{
						$data['feedback_form'] = '';
					}
					// 	</yoga_feedback_extension>
				]]>
			</add>
		</operation>
	</file>
    <file path="catalog/view/theme/*/template/common/header.twig">
		<operation>
			<search>
				<![CDATA[
					</nav>
				]]>
			</search>
			<add position="after">
				<![CDATA[
                    {{ feedback_form }}
				]]>
			</add>
		</operation>
	</file>
    <file path="catalog/controller/common/footer.php">
		<operation>
			<search>
				<![CDATA[
					$data['scripts'] = $this->document->getScripts('footer');
				]]>
			</search>
			<add position="before">
				<![CDATA[
					// 	<yoga_feedback_extension>
					$this->document->addStyle('catalog/view/javascript/yoga_feedback/yoga_feedback_modal.css');
					$this->document->addScript('catalog/view/javascript/yoga_feedback/yoga_feedback_modal.js');
                ]]>
			</add>
		</operation>
	</file>
    <file path="admin/controller/common/header.php">
		<operation error='skip'>
			<search><![CDATA[
				$data['developer'] = $this->user->hasPermission('access', 'common/developer');
			]]></search>
			<add position="after" offset='4'><![CDATA[
				// 	<yoga_feedback_extension>
	            $data['feedbacks'] = $this->url->link('extension/module/yoga_feedback', 'user_token=' . $this->session->data['user_token'], true);
                // 	</yoga_feedback_extension>
			]]></add>
		</operation>
	</file>
</modification>